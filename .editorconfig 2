# EditorConfig helps maintain consistent coding styles between different editors and IDEs
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Default indentation (override per-language below if needed)
indent_style = space
indent_size = 2

# JavaScript / Objective-J (tree-sitter grammar and related scripts)
[*.{js,cjs,mjs}]
indent_style = space
indent_size = 2
max_line_length = off

# JSON and JSONC
[*.{json,jsonc}]
indent_style = space
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown (avoid trimming trailing whitespace; some MD uses it for line breaks)
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# Shell scripts
[*.{sh,bash,zsh}]
indent_style = space
indent_size = 2

# Objective-C/Objective-C++ (if present in the repo)
[*.{m,mm,h}]
indent_style = space
indent_size = 2
