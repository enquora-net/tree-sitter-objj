{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "objj",
      "camelcase": "ObjJ",
      "title": "Objective-J",
      "scope": "source.objj",
      "file-types": [
        "objj"
      ],
      "injection-regex": "^objj$",
      "class-name": "TreeSitterObjj"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "A Javascript superset with support for classes and message passing",
    "authors": [
      {
        "name": "David Richardson",
        "email": "david.richardson@enquora.com"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-objj"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}